# NCBI E-utilities (PubMed). Copy to .env and fill in your values.
# Get an API key: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_EMAIL=your@email.com
NCBI_API_KEY=

# OpenAI (for RAG when config/pipeline.yaml rag.llm_provider is "openai")
# Get an API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
